{
  "label": "Text to KG Basic",
  "description": "Scatters multiple text entities, chunks and extracts knowledge graph entities with deduplication",
  "version": "2.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "chunk" }
    },
    "chunk": {
      "klados": { "id": "$TEXT_CHUNKER_KLADOS" },
      "then": { "scatter": "extract" }
    },
    "extract": {
      "klados": { "id": "$KG_EXTRACTOR_KLADOS" },
      "then": { "scatter": "dedupe" }
    },
    "dedupe": {
      "klados": { "id": "$KG_DEDUPE_RESOLVER_KLADOS" },
      "then": { "done": true }
    }
  }
}
