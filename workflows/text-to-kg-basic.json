{
  "label": "Text to KG Basic",
  "description": "Scatters multiple text entities, chunks and extracts knowledge graph entities.",
  "version": "3.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "chunk" }
    },
    "chunk": {
      "klados": { "id": "$TEXT_CHUNKER_KLADOS" },
      "then": { "scatter": "kg_process" }
    },
    "kg_process": {
      "klados": { "id": "$KG_BASIC_SINGLE_RHIZA", "type": "rhiza" },
      "then": { "done": true }
    }
  }
}
