{
  "label": "Image to KG Basic",
  "description": "Scatters multiple images, converts to JPEG, extracts text via OCR, and extracts knowledge graph entities with deduplication. Extracted images are described before KG extraction.",
  "version": "2.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "convert" }
    },
    "convert": {
      "klados": { "id": "$IMAGE_CONVERTER_KLADOS" },
      "then": { "pass": "ocr" }
    },
    "ocr": {
      "klados": { "id": "$OCR_WORKER_KLADOS" },
      "then": {
        "scatter": "extract",
        "route": [
          {
            "where": { "property": "entity_class", "equals": "extracted_image" },
            "target": "describe_image"
          }
        ]
      }
    },
    "describe_image": {
      "klados": { "id": "$DESCRIBE_KLADOS" },
      "then": { "pass": "extract" }
    },
    "extract": {
      "klados": { "id": "$KG_EXTRACTOR_KLADOS" },
      "then": { "scatter": "dedupe" }
    },
    "dedupe": {
      "klados": { "id": "$KG_DEDUPE_RESOLVER_KLADOS" },
      "then": { "done": true }
    }
  }
}
