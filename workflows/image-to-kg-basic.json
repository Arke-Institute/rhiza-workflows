{
  "label": "Image to KG Basic",
  "description": "End-to-end pipeline for non-JPEG image files (TIFF, PNG, WebP, GIF, BMP): scatters multiple images, converts to JPEG, extracts text via OCR, then extracts knowledge graph entities. For JPEGs use jpeg-to-kg, for PDFs use pdf-to-kg. Handles all file processing automatically — use this instead of KG-only workflows for image input.",
  "version": "3.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "convert" }
    },
    "convert": {
      "klados": { "id": "$IMAGE_CONVERTER_KLADOS" },
      "then": { "pass": "ocr" }
    },
    "ocr": {
      "klados": { "id": "$OCR_WORKER_KLADOS" },
      "then": {
        "scatter": "kg_process",
        "route": [
          {
            "where": { "property": "entity_class", "equals": "extracted_image" },
            "target": "describe_image"
          }
        ]
      }
    },
    "describe_image": {
      "klados": { "id": "$DESCRIBE_KLADOS" },
      "input": {
        "update_label": true
      },
      "then": { "pass": "kg_process" }
    },
    "kg_process": {
      "klados": { "id": "$KG_BASIC_SINGLE_RHIZA", "type": "rhiza" },
      "then": { "done": true }
    }
  }
}
