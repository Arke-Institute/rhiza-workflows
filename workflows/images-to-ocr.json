{
  "label": "Images to OCR",
  "description": "Scatters multiple images, converts each to JPEG, and extracts text via OCR",
  "version": "1.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "convert" }
    },
    "convert": {
      "klados": { "id": "$IMAGE_CONVERTER_KLADOS" },
      "then": { "pass": "ocr" }
    },
    "ocr": {
      "klados": { "id": "$OCR_WORKER_KLADOS" },
      "then": { "done": true }
    }
  }
}
