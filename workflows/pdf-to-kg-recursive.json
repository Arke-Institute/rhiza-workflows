{
  "label": "PDF to KG Recursive",
  "status": "development",
  "description": "[EXPERIMENTAL] End-to-end pipeline for raw PDF files with recursive KG processing: scatters PDFs, extracts text (digital) or converts and OCRs (scanned), then extracts, deduplicates, clusters, describes, and recursively re-clusters. Handles all file processing automatically. This workflow includes clustering steps that are currently unreliable. Not recommended for production use.",
  "version": "3.1",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "pdf_convert" }
    },
    "pdf_convert": {
      "klados": { "id": "$PDF_TO_JPEG_KLADOS" },
      "then": {
        "scatter": "ocr",
        "route": [
          {
            "where": { "property": "needs_ocr", "equals": false },
            "target": "extract"
          }
        ]
      }
    },
    "ocr": {
      "klados": { "id": "$OCR_WORKER_KLADOS" },
      "then": {
        "scatter": "extract",
        "route": [
          {
            "where": { "property": "entity_class", "equals": "extracted_image" },
            "target": "describe_image"
          }
        ]
      }
    },
    "describe_image": {
      "klados": { "id": "$DESCRIBE_KLADOS" },
      "input": {
        "update_label": true
      },
      "then": { "pass": "extract" }
    },
    "extract": {
      "klados": { "id": "$KG_EXTRACTOR_KLADOS" },
      "then": { "scatter": "dedupe" }
    },
    "dedupe": {
      "klados": { "id": "$KG_DEDUPE_RESOLVER_KLADOS" },
      "then": { "scatter": "cluster" }
    },
    "cluster": {
      "klados": { "id": "$KG_CLUSTER_KLADOS" },
      "input": {
        "initial_delay_max_ms": 30000,
        "follower_wait_min_ms": 30000,
        "follower_wait_max_ms": 60000,
        "follower_poll_interval_ms": 5000
      },
      "then": { "scatter": "describe" }
    },
    "describe": {
      "klados": { "id": "$DESCRIBE_KLADOS" },
      "input": {
        "update_label": true,
        "style": "detailed",
        "custom_instructions": "Use existing label if appropriate. Focus on creating a concise, informative description that captures the essence of the entity and its relationships."
      },
      "then": {
        "recurse": "cluster",
        "max_depth": 10
      }
    }
  }
}
