{
  "label": "JPEG to KG Basic",
  "description": "Scatters multiple JPEGs, extracts text via OCR and extracts knowledge graph entities. Extracted images are described before KG extraction.",
  "version": "3.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "ocr" }
    },
    "ocr": {
      "klados": { "id": "$OCR_WORKER_KLADOS" },
      "then": {
        "scatter": "kg_process",
        "route": [
          {
            "where": { "property": "entity_class", "equals": "extracted_image" },
            "target": "describe_image"
          }
        ]
      }
    },
    "describe_image": {
      "klados": { "id": "$DESCRIBE_KLADOS" },
      "then": { "pass": "kg_process" }
    },
    "kg_process": {
      "klados": { "id": "$KG_BASIC_SINGLE_RHIZA", "type": "rhiza" },
      "then": { "done": true }
    }
  }
}
