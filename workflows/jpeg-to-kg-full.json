{
  "label": "JPEG to KG Full",
  "status": "development",
  "description": "[EXPERIMENTAL] Scatters multiple JPEGs, extracts text via OCR and extracts knowledge graph with clustering and descriptions. This workflow includes dedupe and clustering steps that are currently unreliable and may produce unpredictable results. Not recommended for production use.",
  "version": "3.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "ocr" }
    },
    "ocr": {
      "klados": { "id": "$OCR_WORKER_KLADOS" },
      "then": {
        "scatter": "kg_process",
        "route": [
          {
            "where": { "property": "entity_class", "equals": "extracted_image" },
            "target": "describe_image"
          }
        ]
      }
    },
    "describe_image": {
      "klados": { "id": "$DESCRIBE_KLADOS" },
      "then": { "pass": "kg_process" }
    },
    "kg_process": {
      "klados": { "id": "$KG_FULL_SINGLE_RHIZA", "type": "rhiza" },
      "then": { "done": true }
    }
  }
}
