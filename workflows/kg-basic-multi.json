{
  "label": "KG Basic (Multi)",
  "description": "Scatters multiple entities, extracts and deduplicates knowledge graph entities. Multi-entity entry point with built-in scatter.",
  "version": "3.0",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "extract" }
    },
    "extract": {
      "klados": { "id": "$KG_EXTRACTOR_KLADOS" },
      "then": { "scatter": "dedupe" }
    },
    "dedupe": {
      "klados": { "id": "$KG_DEDUPE_RESOLVER_KLADOS" },
      "then": { "done": true }
    }
  }
}
